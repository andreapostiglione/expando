<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.inochisrl.expando</string>
    <key>ProgramArguments</key>
    <array>
        <string>__EXPANDO_ROOT__/scripts/launch-expando.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__HOME__/Library/Application Support/expando/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Application Support/expando/launchd.err.log</string>
    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>